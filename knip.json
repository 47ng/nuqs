{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "packages/nuqs": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@vitejs/plugin-react"]
    },
    "packages/docs": {
      "entry": [
        "source.config.ts",
        "rehype-code.config.ts",
        "content/**/*.{ts,tsx,mdx}",
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/route.ts",
        "src/components/audience.tsx",
        "src/components/code-block-highlighter.ts",
        "src/components/feature-support-matrix.tsx",
        "src/components/frameworks.tsx"
      ],
      "project": [
        "source.config.ts",
        "rehype-code.config.ts",
        "content/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}"
      ],
      "paths": {
        "@/*": ["./*"]
      },
      "next": true,
      "ignoreFiles": [
        "src/components/code-block-highlighter.skeleton.ts",
        "src/components/github-profile.tsx",
        "src/components/kibo-ui/**",
        "src/components/release-contribution-graph.client.tsx",
        "src/components/release-contribution-graph.tsx",
        "src/components/ui/pr-line.tsx",
        "src/components/ui/switch.tsx",
        "src/components/vercel-oss-badge.tsx"
      ],
      "ignoreDependencies": [
        "@headlessui/tailwindcss",
        "@radix-ui/react-switch",
        "@tailwindcss/container-queries",
        "@types/mdx",
        "date-fns",
        "hast-util-to-jsx-runtime",
        "import-in-the-middle",
        "require-in-the-middle",
        "tailwindcss-animate"
      ]
    },
    "packages/e2e/shared": {
      "entry": [
        "shared.spec.ts",
        "playwright/*.ts",
        "specs/**/*.{ts,tsx}",
        "components/**/*.tsx",
        "lib/options.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/e2e/next": {
      "entry": [
        "src/app/**/*.{ts,tsx}",
        "src/pages/**/*.{ts,tsx}",
        "src/components/**/*.tsx",
        "specs/**/*.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignore": [".next/**"]
    },
    "packages/e2e/react": {
      "entry": ["src/main.tsx", "specs/**/*.ts"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/e2e/remix": {
      "entry": ["app/**/*.{ts,tsx}", "specs/**/*.ts"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["build/**"]
    },
    "packages/e2e/tanstack-router": {
      "entry": [
        "src/main.tsx",
        "src/routes/**/*.tsx",
        "src/routeTree.gen.ts",
        "specs/**/*.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["node_modules/**"]
    },
    "packages/e2e/react-router/v5": {
      "entry": ["src/main.tsx", "specs/**/*.ts"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/e2e/react-router/v6": {
      "entry": ["src/main.tsx", "src/routes/**/*.tsx", "specs/**/*.ts"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/e2e/react-router/v7": {
      "entry": ["app/**/*.{ts,tsx}", "server.mjs", "specs/**/*.ts"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["build/**", ".react-router/**"]
    },
    "packages/examples/next-app": {
      "entry": ["src/app/**/*.{ts,tsx}", "next.config.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "next": true,
      "ignoreDependencies": ["postcss", "tailwindcss"]
    },
    "packages/examples/trpc": {
      "entry": ["app/**/*.{ts,tsx}", "server.mjs"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["build/**", ".react-router/**"]
    }
  },
  "ignoreIssues": {
    "packages/docs/src/components/ui/**": ["exports", "types"]
  },
  "rules": {
    "optionalPeerDependencies": "off"
  }
}
